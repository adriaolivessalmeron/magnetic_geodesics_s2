      RowBox[{"x_", "?", "NumericQ"}], ",", " ", 
      RowBox[{"a_", "?", "NumericQ"}], ",", " ", 
      RowBox[{"b_", "?", "NumericQ"}], ",", " ", 
      RowBox[{"tol_", ":", " ", 
