Cell[CellGroupData[{

Cell[TextData[{
 "3. Numerical and analytic ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4e2bd39d-58a2-7b44-bb7b-4b016fadbebd"],
 " equations"
}], "Section",
 CellChangeTimes->{{3.9927196790310593`*^9, 3.9927196903014297`*^9}},
 FontColor->RGBColor[0.75, 0, 0],
 Background->GrayLevel[
  0.85],ExpressionUUID->"1ba82261-c222-a744-9e21-5aa8dcabdd2e"],

Cell[TextData[{
 "NDSolve gives the numerical solution for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "705fecff-325c-a341-8d6a-4298428da892"],
 ", namely ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Theta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8e6c17e2-402d-2143-9a6a-3cd6a667316e"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "78f7dbb4-379b-c64d-a0c1-944722d5661d"],
 ". The analytic ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49e74b07-4efd-db47-8a5d-2bf36c10344e"],
 " expression is obtained by integrating the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f14ab5c0-204b-d548-808e-7eac658a2fb2"],
 " equation \n\t\t\t\t\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Phi]", "."], "\[LongEqual]", 
         FractionBox["\[ScriptL]", 
          RowBox[{
            SuperscriptBox[
             StyleBox["R", "TI"], "2"], 
            SuperscriptBox["sin", "2"], 
            RowBox[{"(", "\[Theta]", ")"}]}]], "+", 
         FractionBox["\[Alpha]\[Rho]", 
          SuperscriptBox[
           StyleBox["R", "TI"], "2"]], "+", 
         FractionBox[
          RowBox[{
            StyleBox["q", "TI"], 
            SubscriptBox["\[Mu]\[Lambda]", 
             StyleBox["I", "TI"]], "cos", 
            RowBox[{"(", "\[Theta]", ")"}]}], 
          RowBox[{
            SuperscriptBox["sin", "2"], "(", "\[Theta]", ")"}]], 
         "\[LongEqual]", 
         FractionBox["\[ScriptL]", 
          RowBox[{
            SuperscriptBox[
             StyleBox["R", "TI"], "2"], "(", 
            RowBox[{"1", "-", 
              SuperscriptBox[
               StyleBox["x", "TI"], "2"]}], ")"}]], "+", 
         FractionBox["\[Alpha]\[Rho]", 
          SuperscriptBox[
           StyleBox["R", "TI"], "2"]], "+", 
         FractionBox[
          RowBox[{
            StyleBox["q", "TI"], 
            SubscriptBox["\[Mu]\[Lambda]", 
             StyleBox["I", "TI"]], 
            StyleBox["x", "TI"]}], 
          RowBox[{"1", "-", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\dot\\phi &= \
\\frac{\\ell}{R^2\\sin^2(\\theta)}+\\frac{\\alpha\\rho}{R^2}+\\frac{q\\mu\\\
lambda_I\\cos(\\theta)}{\\sin^2(\\theta)} = \\frac{\\ell}{R^2(1-x^2)}+\\frac{\
\\alpha\\rho}{R^2}+\\frac{q\\mu\\lambda_Ix}{1-x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2205b09-49ce-8e4b-a1b8-f19a151d28b7"],
 "\nalong the detected analytic ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5df5770c-e7ad-724c-a553-241e103150c6"],
 "-branch."
}], "Text",
 CellChangeTimes->{{3.9927196829743805`*^9, 3.992719701572996*^9}, {
   3.9927489160128136`*^9, 3.9927489316504555`*^9}, 3.992748977438154*^9, {
   3.9927491456613464`*^9, 3.992749156127659*^9}, {3.9927492153596897`*^9, 
   3.9927492202566624`*^9}, {3.992749277707756*^9, 
   3.992749283050974*^9}},ExpressionUUID->"be9f9835-fb41-3045-a5fb-\
4280d055b68d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"solveNumerical", ",", " ", "solveAnalyticPhi"}], "]"}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"solveNumerical", "[", "data_", "]"}], " ", ":=", "\n", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tauMax", ",", " ", "x0", ",", " ", "dx0", ",", " ", "phi0", ",", " ", 
        "sol", ",", " ", "xSol", ",", " ", "phiSol", ",", " ", "tEnd"}], 
       "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", " ", 
          RowBox[{"TrueQ", "[", 
           RowBox[{"get", "[", 
            RowBox[{"data", ",", " ", "\"\<Valid\>\""}], "]"}], "]"}]}], ",", 
         "\n", "   ", 
         RowBox[{"Return", "[", 
          RowBox[{"fail", "[", 
           RowBox[{"\"\<InvalidData\>\"", ",", " ", 
            RowBox[{"get", "[", 
             RowBox[{"data", ",", " ", "\"\<Message\>\""}], "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"\"\<ConstraintDefect\>\"", " ", "->", " ", 
              RowBox[{"get", "[", 
               RowBox[{"data", ",", " ", "\"\<ConstraintDefect\>\""}], 
               "]"}]}], "}"}]}], "]"}], "]"}]}], "\n", "   ", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"At", " ", "a", " ", "regular", " ", "pole"}], ",", " ", 
         RowBox[{"x0", "=", " ", 
          RowBox[{
          "pm1", " ", "is", " ", "at", " ", "least", " ", "a", " ", "double", 
           " ", "root", " ", "of", " ", "P"}]}], ",", " ", 
         RowBox[{
          RowBox[{"so", " ", "P", 
           RowBox[{"(", "x0", ")"}]}], "=", 
          RowBox[{
           RowBox[{
            RowBox[{"P", "'"}], 
            RowBox[{"(", "x0", ")"}]}], "=", 
           RowBox[{
            RowBox[{"0.", " ", "Together", " ", "with", " ", 
             RowBox[{"x", "'"}], 
             RowBox[{"(", "0", ")"}]}], "=", "0"}]}]}], ",", 
         RowBox[{
          RowBox[{
          "this", " ", "gives", " ", "the", " ", "static", " ", "solution", " ",
            "x", 
           RowBox[{"(", "tau", ")"}]}], "=", 
          RowBox[{
           RowBox[{"x0", ".", "This"}], " ", "is", " ", "Case", " ", "6"}]}], 
         ",", 
         RowBox[{
          RowBox[{
          "or", " ", "Case", " ", "9", " ", "if", " ", "the", " ", "root", " ",
            "is", " ", 
           RowBox[{"triple", ".", " ", "The"}], " ", "azimuthal", " ", 
           "coordinate", " ", "phi", " ", "is", " ", "undefined", " ", "at", " ",
            "a", " ", 
           RowBox[{"pole", ":", " ", 
            RowBox[{
            "every", " ", "value", " ", "of", " ", "phi", " ", "represents", " ",
              "the", " ", "same", " ", "point", " ", "on", " ", "the", " ", 
             RowBox[{"sphere", ".", " ", "We"}], " ", "therefore", " ", "set",
              " ", "phi", 
             RowBox[{"(", "tau", ")"}]}]}]}], "=", 
          RowBox[{
          "phi0", " ", "as", " ", "a", " ", "convenient", " ", "coordinate", " ", 
