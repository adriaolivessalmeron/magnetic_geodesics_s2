  RowBox[{"(*", 
   RowBox[{
   "determines", " ", "the", " ", "deg", " ", "of", " ", "P", " ", "with", " ",
     "tolerance"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"polyDegree", "[", 
     RowBox[{
     "a0_", ",", " ", "a1_", ",", " ", "a2_", ",", " ", "a3_", ",", " ", 
      RowBox[{"tol_", ":", " ", 
       RowBox[{"10", "^", 
        RowBox[{"-", "10"}]}]}]}], "]"}], " ", ":=", "\n", "  ", 
    RowBox[{"Which", "[", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", "a3", "]"}], " ", ">", " ", "tol"}], ",", " ", "3",
       ",", " ", 
      RowBox[{"(*", 
       RowBox[{"condici\[OAcute]n", ",", " ", "resultado"}], "*)"}], "\n", 
      "   ", 
      RowBox[{
       RowBox[{"Abs", "[", "a2", "]"}], " ", ">", " ", "tol"}], ",", " ", "2",
       ",", "\n", "   ", 
      RowBox[{
       RowBox[{"Abs", "[", "a1", "]"}], " ", ">", " ", "tol"}], ",", " ", "1",
       ",", "\n", "   ", 
      RowBox[{
       RowBox[{"Abs", "[", "a0", "]"}], " ", ">", " ", "tol"}], ",", " ", "0",
       ",", "\n", "   ", "True", ",", " ", 
      RowBox[{"-", "Infinity"}]}], "\n", "   ", "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "return", " ", "the", " ", "roots", " ", "and", " ", "its", " ", 
    "multiplicities"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"realRootGroups", "[", 
     RowBox[{
     "a0_", ",", " ", "a1_", ",", " ", "a2_", ",", " ", "a3_", ",", " ", 
      RowBox[{"tol_", ":", " ", 
       RowBox[{"10", "^", 
        RowBox[{"-", "10"}]}]}]}], "]"}], " ", ":=", "\n", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "xx", ",", " ", "deg", ",", " ", "poly", ",", " ", "dpoly", ",", " ", 
        "ddpoly", ",", " ", "roots", ",", " ", "realRoots", ",", " ", 
        "groups", ",", " ", "rts", ",", " ", "mults"}], "}"}], ",", "\n", 
      "  ", 
      RowBox[{
       RowBox[{"deg", " ", "=", " ", 
        RowBox[{"polyDegree", "[", 
         RowBox[{
         "a0", ",", " ", "a1", ",", " ", "a2", ",", " ", "a3", ",", " ", 
          "tol"}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"poly", " ", "=", " ", 
        RowBox[{
         RowBox[{"a3", " ", 
          RowBox[{"xx", "^", "3"}]}], " ", "+", " ", 
         RowBox[{"a2", " ", 
          RowBox[{"xx", "^", "2"}]}], " ", "+", " ", 
         RowBox[{"a1", " ", "xx"}], " ", "+", " ", "a0"}]}], ";", "\n", "  ", 
       RowBox[{
        RowBox[{"dpoly", "[", "z_", "]"}], " ", ":=", " ", 
        RowBox[{
         RowBox[{"3", " ", "a3", " ", 
          RowBox[{"z", "^", "2"}]}], " ", "+", " ", 
         RowBox[{"2", " ", "a2", " ", "z"}], " ", "+", " ", "a1"}]}], ";", 
       "\n", "  ", 
       RowBox[{
        RowBox[{"ddpoly", "[", "z_", "]"}], " ", ":=", " ", 
        RowBox[{
         RowBox[{"6", " ", "a3", " ", "z"}], " ", "+", " ", 
         RowBox[{"2", " ", "a2"}]}]}], ";", "\n", "  ", 
       RowBox[{"roots", " ", "=", " ", 
        RowBox[{"xx", " ", "/.", " ", 
         RowBox[{"NSolve", "[", 
          RowBox[{
           RowBox[{"poly", " ", "==", " ", "0"}], ",", " ", "xx"}], "]"}]}]}],
        ";", "\n", "  ", 
       RowBox[{"realRoots", " ", "=", " ", 
        RowBox[{"Sort", "[", 
         RowBox[{"Re", " ", "/@", " ", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"N", "[", "roots", "]"}], ",", " ", 
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"Im", "[", "#", "]"}], "]"}], " ", "<", " ", 
              RowBox[{"100", " ", "tol"}]}], " ", "&"}]}], "]"}]}], "]"}]}], ";",
        "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"realRoots", " ", "===", " ", 
          RowBox[{"{", "}"}]}], ",", " ", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\"\<Roots\>\"", " ", "->", " ", 
             RowBox[{"{", "}"}]}], ",", " ", 
            RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", 
             RowBox[{"{", "}"}]}]}], "}"}], "]"}]}], "]"}], ";", "\n", "  ", 
       RowBox[{"groups", " ", "=", " ", 
        RowBox[{"Split", "[", 
         RowBox[{"realRoots", ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"#1", " ", "-", " ", "#2"}], "]"}], " ", "<", " ", 
            RowBox[{"100", " ", "tol"}]}], " ", "&"}]}], "]"}]}], ";", "\n", 
       "  ", 
       RowBox[{"rts", " ", "=", " ", 
        RowBox[{"N", "[", 
         RowBox[{"Mean", " ", "/@", " ", "groups"}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"mults", " ", "=", " ", 
        RowBox[{"Length", " ", "/@", " ", "groups"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"deg", " ", "==", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "rts", "]"}], " ", "==", " ", "1"}]}], ",", 
         "\n", "   ", 
         RowBox[{"mults", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"dpoly", "[", 
                 RowBox[{"rts", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], " ", "<", " ", 
               RowBox[{"100", " ", "tol"}]}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"ddpoly", "[", 
                 RowBox[{"rts", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], " ", "<", " ", 
               RowBox[{"100", " ", "tol"}]}]}], ",", " ", "3", ",", " ", 
             "1"}], "]"}], "}"}]}]}], "\n", "   ", "]"}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"deg", " ", "==", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "rts", "]"}], " ", "==", " ", "2"}]}], ",", 
         "\n", "   ", 
         RowBox[{"mults", " ", "=", " ", 
          RowBox[{"Which", "[", "\n", "     ", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"dpoly", "[", 
               RowBox[{"rts", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], " ", "<", " ", 
             RowBox[{"100", " ", "tol"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"2", ",", " ", "1"}], "}"}], ",", "\n", "     ", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"dpoly", "[", 
               RowBox[{"rts", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}], " ", "<", " ", 
             RowBox[{"100", " ", "tol"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "2"}], "}"}], ",", "\n", "     ", "True", 
            ",", " ", "mults"}], "\n", "     ", "]"}]}]}], "\n", "   ", "]"}],
        ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"deg", " ", "==", " ", "2"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "rts", "]"}], " ", "==", " ", "1"}]}], ",", 
         "\n", "   ", 
         RowBox[{"mults", " ", "=", " ", 
          RowBox[{"{", "2", "}"}]}]}], "\n", "   ", "]"}], ";", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<Roots\>\"", " ", "->", " ", "rts"}], ",", " ", 
         RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", "mults"}]}], 
        "}"}]}]}], "\n", "  ", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Format", " ", "of", " ", "an", " ", "analytical", " ", "branch"}],
    "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"branch", "[", 
    RowBox[{"case_", ",", " ", "xFun_", ",", " ", 
     RowBox[{"roots_", ":", " ", 
      RowBox[{"{", "}"}]}], ",", " ", 
     RowBox[{"mults_", ":", " ", 
      RowBox[{"{", "}"}]}], ",", " ", 
     RowBox[{"pars_", ":", " ", 
      RowBox[{"{", "}"}]}]}], "]"}], " ", ":=", " ", 
