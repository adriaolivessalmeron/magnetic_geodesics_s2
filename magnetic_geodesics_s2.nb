       RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"clip01", "[", 
    RowBox[{"z_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"Clip", "[", 
    RowBox[{
     RowBox[{"N", "[", "z", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"clipOpen01", "[", 
