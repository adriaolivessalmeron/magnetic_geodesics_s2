Cell[TextData[{
 "This notebook compares the numerical solution obtained with NDSolve with \
the analytic branch selected from the root structure of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["P", "TI"], TraditionalForm], "errors" -> {}, "input" -> "P", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7ed8baaf-7bf1-e54c-a69a-e4989cde6195"],
 ". The numbering follows the classification table in the Appendix, and the \
preset buttons fill the parameters automatically."
}], "Text",
 CellChangeTimes->{3.992691311197344*^9, 
  3.9927196358302593`*^9},ExpressionUUID->"214a3803-1543-9046-8684-\
9a5fdb75cba3"],

