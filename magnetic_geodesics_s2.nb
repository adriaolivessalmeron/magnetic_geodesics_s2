Cell[CellGroupData[{

Cell["2. Analytic branch selection", "Section",
 FontColor->RGBColor[0.75, 0, 0],
 Background->GrayLevel[
  0.85],ExpressionUUID->"45fae1b1-f565-7c46-8c0b-dde36f5a0512"],

Cell["\<\
Detection of the analytic branch in the order of the Appendix classification: \
cases 1 to 9.\
\>", "Text",
 CellChangeTimes->{
  3.992719669061287*^9},ExpressionUUID->"3e6aba8a-c395-b04a-ad4b-\
84b07991ce2a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "buildAnalyticX", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"buildAnalyticX", "[", 
     RowBox[{"data_", ",", " ", 
      RowBox[{"tol_", ":", " ", 
       RowBox[{"10", "^", 
        RowBox[{"-", "10"}]}]}]}], "]"}], " ", ":=", "\n", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "a0", ",", " ", "a1", ",", " ", "a2", ",", " ", "a3", ",", " ", "deg", 
        ",", " ", "x0", ",", " ", "dx0", ",", " ", "rootsData", ",", " ", 
        "roots", ",", " ", "mults", ",", " ", "r", ",", " ", "r1", ",", " ", 
        "r2", ",", " ", "r3", ",", " ", "d", ",", " ", "d12", ",", " ", "d23",
         ",", " ", "d13", ",", " ", "m", ",", " ", "omega", ",", " ", "z0", ",",
         " ", "phase", ",", " ", "eps", ",", " ", "xFun"}], "}"}], ",", "\n", 
      "  ", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", " ", 
          RowBox[{"TrueQ", "[", 
           RowBox[{"get", "[", 
            RowBox[{"data", ",", " ", "\"\<Valid\>\""}], "]"}], "]"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"fail", "[", 
           RowBox[{"\"\<InvalidData\>\"", ",", " ", 
            RowBox[{"get", "[", 
             RowBox[{"data", ",", " ", "\"\<Message\>\""}], "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"\"\<ConstraintDefect\>\"", " ", "->", " ", 
              RowBox[{"get", "[", 
               RowBox[{"data", ",", " ", "\"\<ConstraintDefect\>\""}], 
               "]"}]}], "}"}]}], "]"}], "]"}]}], "]"}], ";", "\n", "  ", 
       RowBox[{"a0", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<a0\>\""}], "]"}]}], ";", " ", 
       RowBox[{"a1", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<a1\>\""}], "]"}]}], ";", " ", 
       RowBox[{"a2", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<a2\>\""}], "]"}]}], ";", " ", 
       RowBox[{"a3", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<a3\>\""}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"deg", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<Degree\>\""}], "]"}]}], ";", "\n", 
       "  ", 
       RowBox[{"x0", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<x0\>\""}], "]"}]}], ";", " ", 
       RowBox[{"dx0", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"data", ",", " ", "\"\<dx0\>\""}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"deg", " ", "===", " ", 
          RowBox[{"-", "Infinity"}]}], ",", 
         RowBox[{"(*", 
          RowBox[{"P", " ", "=", " ", "0"}], "*)"}], "\n", "   ", 
         RowBox[{"Return", "[", 
          RowBox[{"staticBranch", "[", 
           RowBox[{
           "x0", ",", " ", "\"\<Case 1: degree 0, P = 0, constant\>\""}], 
           "]"}], "]"}]}], "\n", "   ", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Case", " ", "1"}], "*)"}], "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"deg", " ", "===", " ", "0"}], ",", "\n", "   ", 
         RowBox[{"Return", "[", 
          RowBox[{"fail", "[", 
           
           RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
            " ", "\"\<P is constant and non-zero.\>\""}], "]"}], "]"}]}], 
        "\n", "   ", "]"}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"deg", " ", "===", " ", "1"}], ",", "\n", "   ", 
         RowBox[{"Return", "[", 
          RowBox[{"fail", "[", 
           
           RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
            " ", "\"\<The linear case is not realized by the physical \
coefficients.\>\""}], "]"}], "]"}]}], "\n", "   ", "]"}], ";", "\n", "  ", 
       RowBox[{"rootsData", " ", "=", " ", 
        RowBox[{"realRootGroups", "[", 
         RowBox[{
         "a0", ",", " ", "a1", ",", " ", "a2", ",", " ", "a3", ",", " ", 
          "tol"}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"roots", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"rootsData", ",", " ", "\"\<Roots\>\""}], "]"}]}], ";", "\n",
        "  ", 
       RowBox[{"mults", " ", "=", " ", 
        RowBox[{"get", "[", 
         RowBox[{"rootsData", ",", " ", "\"\<Multiplicities\>\""}], "]"}]}], ";",
        "\n", "  ", 
       RowBox[{"Which", "[", "   ", 
        RowBox[{"(*", " ", 
         RowBox[{"los", " ", "dem\[AAcute]s", " ", "casos", " ", 
          RowBox[{"(", 
           RowBox[{"2", "-", "9"}], ")"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Case", " ", "2"}], "*)"}], "\n", "   ", 
        RowBox[{
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "2"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "2"}]}], ",",
          "\n", "   ", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"r1", ",", " ", "r2"}], "}"}], " ", "=", " ", "roots"}], ";",
           "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"a2", " ", "<", " ", 
                RowBox[{"-", "tol"}]}], " ", "&&", " ", 
               RowBox[{"inIntervalQ", "[", 
                RowBox[{
                "x0", ",", " ", "r1", ",", " ", "r2", ",", " ", "tol"}], 
                "]"}]}], ")"}]}], ",", "\n", "    ", 
            RowBox[{"Return", "[", 
             RowBox[{"fail", "[", 
              
              RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
               " ", "\"\<Quadratic polynomial, but not the physical \
oscillatory branch.\>\"", ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
                 
                 RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", 
                  "mults"}]}], "}"}]}], "]"}], "]"}]}], "\n", "    ", "]"}], ";",
           "\n", "   ", 
          RowBox[{"d", " ", "=", " ", 
           RowBox[{"r2", " ", "-", " ", "r1"}]}], ";", "\n", "   ", 
          RowBox[{"omega", " ", "=", " ", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"-", "a2"}], "]"}], "/", "2"}]}], ";", "\n", "   ", 
          RowBox[{"z0", " ", "=", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"clip01", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x0", " ", "-", " ", "r1"}], ")"}], "/", "d"}], "]"}], 
            "]"}]}], ";", 
          RowBox[{"(*", 
           RowBox[{"z0", " ", ":=", " ", 
            RowBox[{
             RowBox[{"sin", 
              RowBox[{"(", "C", ")"}]}], "=", 
             RowBox[{"sqrt", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x0\:200b", "\[Minus]", "r1"}], ")"}], "/", "d"}], 
               "}"}], "\:200b\:200b"}]}]}], "*)"}], "\n", "   ", 
          RowBox[{"phase", " ", "=", " ", 
           RowBox[{"ArcSin", "[", "z0", "]"}]}], ";", 
          RowBox[{"(*", "C", "*)"}], "\n", "  ", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"eps", " ", "fija", " ", "la", " ", "direcci\[OAcute]n", " ", 
             RowBox[{"inicial", ":", " ", 
              RowBox[{"como", " ", "la", " ", "fase", " ", "esta", " ", 
               RowBox[{"en", " ", "[", 
                RowBox[{"0", ",", 
                 RowBox[{"pi", "/", "2"}]}], "]"}]}]}]}], ",", " ", 
            RowBox[{
             RowBox[{"sgn", "[", 
              RowBox[{
               RowBox[{"x", "'"}], 
               RowBox[{"(", "0", ")"}]}], "]"}], " ", "=", " ", 
             RowBox[{
              RowBox[{
               RowBox[{"eps", ".", " ", "En"}], " ", "punto", " ", "de", " ", 
               "retorno", " ", 
               RowBox[{"x", "'"}], 
               RowBox[{"(", "0", ")"}]}], "=", "0"}]}], ",", " ", 
            RowBox[{
            "los", " ", "dos", " ", "signos", " ", "dan", " ", "la", " ", 
             "misma", " ", "solucii\[OAcute]n", " ", 
             RowBox[{"sin", "^", "2"}]}], ",", " ", 
            RowBox[{
             RowBox[{
             "por", " ", "lo", " ", "que", " ", "podemos", " ", "tomar"}], 
             " ", "+", 
             RowBox[{
             "1", " ", "como", " ", "valor", " ", "predeterminado"}]}]}], " ",
            "*)"}], "\[IndentingNewLine]", " ", 
          RowBox[{"eps", " ", "=", " ", 
           RowBox[{"sgnFrom", "[", 
            RowBox[{"dx0", ",", " ", "tol", ",", " ", "1"}], "]"}]}], ";", 
          "\n", "   ", 
          RowBox[{"xFun", " ", "=", " ", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", "tau", "}"}], ",", " ", 
             RowBox[{"r1", " ", "+", " ", 
              RowBox[{"d", " ", 
               RowBox[{
                RowBox[{"Sin", "[", 
                 RowBox[{
                  RowBox[{"omega", " ", "tau"}], " ", "+", " ", 
                  RowBox[{"eps", " ", "phase"}]}], "]"}], "^", "2"}]}]}]}], 
            "]"}]}], ";", "\n", "   ", 
          RowBox[{"branch", "[", 
           
           RowBox[{"\"\<Case 2: degree 2, oscillatory sin^2\>\"", ",", " ", 
            "xFun", ",", " ", "roots", ",", " ", "mults", ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\"\<omega\>\"", " ", "->", " ", "omega"}], ",", " ", 
              RowBox[{"\"\<phase\>\"", " ", "->", " ", "phase"}]}], "}"}]}], 
           "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Case", " ", "3"}], "*)"}], "\n", "   ", 
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "2"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "1"}]}], ",",
          "\n", "   ", 
         RowBox[{
          RowBox[{"r", " ", "=", " ", 
           RowBox[{"roots", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"a2", " ", "<", " ", 
              RowBox[{"-", "tol"}]}], " ", "&&", " ", 
             RowBox[{"inIntervalQ", "[", 
              RowBox[{"x0", ",", " ", "r", ",", " ", "r", ",", " ", 
               RowBox[{"100", " ", "tol"}]}], "]"}]}], ",", "\n", "    ", 
            RowBox[{"staticBranch", "[", 
             RowBox[{
             "r", ",", " ", "\"\<Case 3: degree 2, double root, constant\>\"",
               ",", " ", "roots", ",", " ", "mults"}], "]"}], ",", "\n", 
            "    ", 
            RowBox[{"fail", "[", 
             
             RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
              " ", "\"\<The physical quadratic double-root branch is static \
and requires a2 < 0.\>\"", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
                RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", "mults"}]}],
                "}"}]}], "]"}]}], "\n", "    ", "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Case", " ", "4", " ", "and", " ", "5"}], "*)"}], "\n", 
         "   ", 
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "3"}]}], ",",
          "\n", "   ", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"r1", ",", " ", "r2", ",", " ", "r3"}], "}"}], " ", "=", 
           " ", "roots"}], ";", "\n", "   ", 
          RowBox[{"d13", " ", "=", " ", 
           RowBox[{"r3", " ", "-", " ", "r1"}]}], ";", "\n", "   ", 
          RowBox[{"Which", "[", "\n", "    ", 
           RowBox[{
            RowBox[{
             RowBox[{"a3", " ", ">", " ", "tol"}], " ", "&&", " ", 
             RowBox[{"inIntervalQ", "[", 
              RowBox[{"x0", ",", " ", "r1", ",", " ", "r2", ",", " ", "tol"}],
               "]"}]}], ",", "\n", "    ", 
            RowBox[{
             RowBox[{"d12", " ", "=", " ", 
              RowBox[{"r2", " ", "-", " ", "r1"}]}], ";", "\n", "    ", 
             RowBox[{"m", " ", "=", " ", 
              RowBox[{"d12", "/", "d13"}]}], ";", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{
                RowBox[{"k", "^", "2"}], " ", "=", " ", "m"}], ";", " ", 
               RowBox[{
               "mathematica", " ", "usa", " ", "m", " ", "no", " ", "k", " ", 
                "como", " ", "el", " ", 
                RowBox[{"Schaum", "!"}]}]}], "*)"}], "\n", "    ", 
             RowBox[{"omega", " ", "=", " ", 
              RowBox[{
               RowBox[{"Sqrt", "[", 
                RowBox[{"a3", " ", "d13"}], "]"}], "/", "2"}]}], ";", "\n", 
             "    ", 
             RowBox[{"z0", " ", "=", " ", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"clip01", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"x0", " ", "-", " ", "r1"}], ")"}], "/", "d12"}], 
                "]"}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"phase", "=", 
              RowBox[{"InverseJacobiSN", "[", 
               RowBox[{"z0", ",", "m"}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"eps", " ", "=", " ", 
              RowBox[{"sgnFrom", "[", 
               RowBox[{"dx0", ",", " ", "tol", ",", " ", "1"}], "]"}]}], ";", 
             "\n", "    ", 
             RowBox[{"xFun", " ", "=", " ", 
              RowBox[{"Function", "[", 
               RowBox[{
                RowBox[{"{", "tau", "}"}], ",", " ", 
                RowBox[{"r1", " ", "+", " ", 
                 RowBox[{"d12", " ", 
                  RowBox[{
                   RowBox[{"JacobiSN", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"omega", " ", "tau"}], " ", "+", " ", 
                    RowBox[{"eps", " ", "phase"}]}], ",", " ", "m"}], "]"}], "^",
                    "2"}]}]}]}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"branch", "[", 
              
              RowBox[{"\"\<Case 4: degree 3, a3 > 0, Jacobi oscillatory \
sn^2\>\"", ",", " ", "xFun", ",", " ", "roots", ",", " ", "mults", ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"\"\<m\>\"", " ", "->", " ", "m"}], ",", " ", 
                 RowBox[{"\"\<omega\>\"", " ", "->", " ", "omega"}], ",", " ", 
                 RowBox[{"\"\<phase\>\"", " ", "->", " ", "phase"}]}], 
                "}"}]}], "]"}]}], ",", "\n", "    ", 
            RowBox[{
             RowBox[{"a3", " ", "<", " ", 
              RowBox[{"-", "tol"}]}], " ", "&&", " ", 
             RowBox[{"inIntervalQ", "[", 
              RowBox[{"x0", ",", " ", "r2", ",", " ", "r3", ",", " ", "tol"}],
               "]"}]}], ",", "\n", "    ", 
            RowBox[{
             RowBox[{"d23", " ", "=", " ", 
              RowBox[{"r3", " ", "-", " ", "r2"}]}], ";", "\n", "    ", 
             RowBox[{"m", " ", "=", " ", 
              RowBox[{"d23", "/", "d13"}]}], ";", "\n", "    ", 
             RowBox[{"omega", " ", "=", " ", 
              RowBox[{
               RowBox[{"Sqrt", "[", 
                RowBox[{
                 RowBox[{"-", "a3"}], " ", "d13"}], "]"}], "/", "2"}]}], ";", 
             "\n", "    ", 
             RowBox[{"z0", " ", "=", " ", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"clip01", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"r3", " ", "-", " ", "x0"}], ")"}], "/", "d23"}], 
                "]"}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"phase", " ", "=", " ", 
              RowBox[{"InverseJacobiSN", "[", 
               RowBox[{"z0", ",", "m"}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"eps", "=", 
              RowBox[{"sgnFrom", "[", 
               RowBox[{
                RowBox[{"-", "dx0"}], ",", "tol", ",", "1"}], "]"}]}], ";", 
             "\n", "    ", 
             RowBox[{"xFun", " ", "=", " ", 
              RowBox[{"Function", "[", 
               RowBox[{
                RowBox[{"{", "tau", "}"}], ",", " ", 
                RowBox[{"r3", " ", "-", " ", 
                 RowBox[{"d23", " ", 
                  RowBox[{
                   RowBox[{"JacobiSN", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"omega", " ", "tau"}], " ", "+", " ", 
                    RowBox[{"eps", " ", "phase"}]}], ",", " ", "m"}], "]"}], "^",
                    "2"}]}]}]}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"branch", "[", 
              
              RowBox[{"\"\<Case 5: degree 3, a3 < 0, Jacobi oscillatory \
sn^2\>\"", ",", " ", "xFun", ",", " ", "roots", ",", " ", "mults", ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"\"\<m\>\"", " ", "->", " ", "m"}], ",", " ", 
                 RowBox[{"\"\<omega\>\"", " ", "->", " ", "omega"}], ",", " ", 
                 RowBox[{"\"\<phase\>\"", " ", "->", " ", "phase"}]}], 
                "}"}]}], "]"}]}], ",", "\n", "    ", "True", ",", "\n", 
            "    ", 
            RowBox[{"fail", "[", 
             
             RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
              " ", "\"\<Cubic with three real roots, but x0 is not in a \
bounded branch.\>\"", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
                RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", "mults"}]}],
                "}"}]}], "]"}]}], "\n", "    ", "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Case", " ", "6", " ", "and", " ", "7"}], "*)"}], "\n", 
         "   ", 
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "2"}], " ", 
          "&&", " ", 
          RowBox[{"mults", " ", "===", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "1"}], "}"}]}]}], ",", "\n", "   ", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"r1", ",", " ", "r3"}], "}"}], " ", "=", " ", "roots"}], ";",
           "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"inIntervalQ", "[", 
             RowBox[{"x0", ",", " ", "r1", ",", " ", "r1", ",", " ", 
              RowBox[{"100", " ", "tol"}]}], "]"}], ",", "\n", "    ", 
            RowBox[{"Return", "[", 
             RowBox[{"staticBranch", "[", 
              RowBox[{
              "r1", ",", 
               " ", "\"\<Case 6: degree 3, double root, constant\>\"", ",", 
               " ", "roots", ",", " ", "mults"}], "]"}], "]"}]}], "\n", 
           "    ", "]"}], ";", "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"a3", " ", "<", " ", 
                RowBox[{"-", "tol"}]}], " ", "&&", " ", 
               RowBox[{"inIntervalQ", "[", 
                RowBox[{
                "x0", ",", " ", "r1", ",", " ", "r3", ",", " ", "tol"}], 
                "]"}]}], ")"}]}], ",", "\n", "    ", 
            RowBox[{"Return", "[", 
             RowBox[{"fail", "[", 
              
              RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
               " ", "\"\<Lower double root requires a3 < 0 and x0 in [r1,r3].\
\>\"", ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
                 
                 RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", 
                  "mults"}]}], "}"}]}], "]"}], "]"}]}], "\n", "    ", "]"}], ";",
           "\n", "   ", 
          RowBox[{"d", " ", "=", " ", 
           RowBox[{"r3", " ", "-", " ", "r1"}]}], ";", "\n", "   ", 
          RowBox[{"omega", " ", "=", " ", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"-", "a3"}], " ", "d"}], "]"}], "/", "2"}]}], ";", "\n",
           "   ", 
          RowBox[{"z0", " ", "=", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"clipOpen01", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"r3", " ", "-", " ", "x0"}], ")"}], "/", "d"}], "]"}], 
            "]"}]}], ";", "\n", "   ", 
          RowBox[{"phase", " ", "=", " ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"dx0", " ", ">", " ", "tol"}], ",", " ", 
             RowBox[{"-", 
              RowBox[{"ArcTanh", "[", "z0", "]"}]}], ",", " ", 
             RowBox[{"ArcTanh", "[", "z0", "]"}]}], "]"}]}], ";", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
            "razonamiento", " ", "an\[AAcute]logo", " ", "al", " ", "de", " ",
              "antes", " ", "pero", " ", "teniendo", " ", "en", " ", "cuenta",
              " ", "el", " ", "signo"}], " ", "-"}], " ", "*)"}], "\n", "   ", 
          RowBox[{"xFun", " ", "=", " ", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", "tau", "}"}], ",", " ", 
             RowBox[{"r3", " ", "-", " ", 
              RowBox[{"d", " ", 
               RowBox[{
                RowBox[{"Tanh", "[", 
                 RowBox[{
                  RowBox[{"omega", " ", "tau"}], " ", "+", " ", "phase"}], 
                 "]"}], "^", "2"}]}]}]}], "]"}]}], ";", "\n", "   ", 
          RowBox[{"branch", "[", 
           
           RowBox[{"\"\<Case 7: degree 3, lower double root, hyperbolic \
asymptotic tanh^2\>\"", ",", " ", "xFun", ",", " ", "roots", ",", " ", 
            "mults", ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\"\<omega\>\"", " ", "->", " ", "omega"}], ",", " ", 
              RowBox[{"\"\<phase\>\"", " ", "->", " ", "phase"}]}], "}"}]}], 
           "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Case", " ", "6", " ", "and", " ", "8"}], "*)"}], "\n", 
         "   ", 
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "2"}], " ", 
          "&&", " ", 
          RowBox[{"mults", " ", "===", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "2"}], "}"}]}]}], ",", "\n", "   ", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"r1", ",", " ", "r3"}], "}"}], " ", "=", " ", "roots"}], ";",
           "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"inIntervalQ", "[", 
             RowBox[{"x0", ",", " ", "r3", ",", " ", "r3", ",", " ", 
              RowBox[{"100", " ", "tol"}]}], "]"}], ",", "\n", "    ", 
            RowBox[{"Return", "[", 
             RowBox[{"staticBranch", "[", 
              RowBox[{
              "r3", ",", 
               " ", "\"\<Case 6: degree 3, double root, constant\>\"", ",", 
               " ", "roots", ",", " ", "mults"}], "]"}], "]"}]}], "\n", 
           "    ", "]"}], ";", "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"a3", " ", ">", " ", "tol"}], " ", "&&", " ", 
               RowBox[{"inIntervalQ", "[", 
                RowBox[{
                "x0", ",", " ", "r1", ",", " ", "r3", ",", " ", "tol"}], 
                "]"}]}], ")"}]}], ",", "\n", "    ", 
            RowBox[{"Return", "[", 
             RowBox[{"fail", "[", 
              
              RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
               " ", "\"\<Upper double root requires a3 > 0 and x0 in [r1,r3].\
\>\"", ",", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
                 
                 RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", 
                  "mults"}]}], "}"}]}], "]"}], "]"}]}], "\n", "    ", "]"}], ";",
           "\n", "   ", 
          RowBox[{"d", " ", "=", " ", 
           RowBox[{"r3", " ", "-", " ", "r1"}]}], ";", "\n", "   ", 
          RowBox[{"omega", " ", "=", " ", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"a3", " ", "d"}], "]"}], "/", "2"}]}], ";", "\n", "   ", 
          RowBox[{"z0", " ", "=", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"clipOpen01", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x0", " ", "-", " ", "r1"}], ")"}], "/", "d"}], "]"}], 
            "]"}]}], ";", "\n", "   ", 
          RowBox[{"phase", " ", "=", " ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"dx0", " ", "<", " ", 
              RowBox[{"-", "tol"}]}], ",", " ", 
             RowBox[{"-", 
              RowBox[{"ArcTanh", "[", "z0", "]"}]}], ",", " ", 
             RowBox[{"ArcTanh", "[", "z0", "]"}]}], "]"}]}], ";", "\n", "   ", 
          RowBox[{"xFun", " ", "=", " ", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", "tau", "}"}], ",", " ", 
             RowBox[{"r1", " ", "+", " ", 
              RowBox[{"d", " ", 
               RowBox[{
                RowBox[{"Tanh", "[", 
                 RowBox[{
                  RowBox[{"omega", " ", "tau"}], " ", "+", " ", "phase"}], 
                 "]"}], "^", "2"}]}]}]}], "]"}]}], ";", "\n", "   ", 
          RowBox[{"branch", "[", 
           
           RowBox[{"\"\<Case 8: degree 3, upper double root, hyperbolic \
asymptotic tanh^2\>\"", ",", " ", "xFun", ",", " ", "roots", ",", " ", 
            "mults", ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\"\<omega\>\"", " ", "->", " ", "omega"}], ",", " ", 
              RowBox[{"\"\<phase\>\"", " ", "->", " ", "phase"}]}], "}"}]}], 
           "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Case", " ", "9"}], "*)"}], "\n", "   ", 
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "1"}], " ", 
          "&&", " ", 
          RowBox[{"mults", " ", "===", " ", 
           RowBox[{"{", "3", "}"}]}]}], ",", "\n", "   ", 
         RowBox[{
          RowBox[{"r", " ", "=", " ", 
           RowBox[{"roots", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "   ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"inIntervalQ", "[", 
             RowBox[{"x0", ",", " ", "r", ",", " ", "r", ",", " ", 
              RowBox[{"100", " ", "tol"}]}], "]"}], ",", "\n", "    ", 
            RowBox[{"staticBranch", "[", 
             RowBox[{
             "r", ",", " ", "\"\<Case 9: degree 3, triple root, constant\>\"",
               ",", " ", "roots", ",", " ", "mults"}], "]"}], ",", "\n", 
            "    ", 
            RowBox[{"fail", "[", 
             
             RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
              " ", "\"\<Triple-root case gives only the static physical \
branch.\>\"", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
                RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", "mults"}]}],
                "}"}]}], "]"}]}], "\n", "    ", "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"fails", " ", "restantes"}], "*)"}], "\n", "   ", 
         RowBox[{
          RowBox[{"deg", " ", "===", " ", "3"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"Length", "[", "roots", "]"}], " ", "==", " ", "1"}]}], ",",
          "\n", "   ", 
         RowBox[{"fail", "[", 
          
          RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
           " ", "\"\<Cubic with one real root and two complex conjugate roots \
has no global physical branch.\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
             RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", "mults"}]}], 
            "}"}]}], "]"}], ",", "\n", "   ", "True", ",", "\n", "   ", 
         RowBox[{"fail", "[", 
          
          RowBox[{"\"\<NoPhysicalBranch\>\"", ",", 
           " ", "\"\<No admissible physical analytic branch detected.\>\"", ",",
            " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\"\<Roots\>\"", " ", "->", " ", "roots"}], ",", " ", 
             RowBox[{"\"\<Multiplicities\>\"", " ", "->", " ", "mults"}]}], 
            "}"}]}], "]"}]}], "\n", "   ", "]"}]}]}], "\n", "  ", "]"}]}], 
   ";"}], "\n"}], "\n"}], "Input",
