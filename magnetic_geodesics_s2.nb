      RowBox[{"Alignment", "->", "Center"}], ",", 
      RowBox[{"Spacings", "->", 
       RowBox[{"{", 
        RowBox[{"0.30", ",", "0"}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
