     RowBox[{
      RowBox[{"1", " ", "-", " ", 
       RowBox[{"10", "^", 
        RowBox[{"-", "10"}]}]}], ",", " ", 
      RowBox[{"Max", "[", 
       RowBox[{"0", ",", " ", 
        RowBox[{"N", "[", "z", "]"}]}], "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"obtain", " ", "the", " ", "sign"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"sgnFrom", "[", 
     RowBox[{
      RowBox[{"z_", "?", "NumericQ"}], ",", " ", 
      RowBox[{"tol_", ":", " ", 
       RowBox[{"10", "^", 
        RowBox[{"-", "10"}]}]}], ",", " ", 
      RowBox[{"default_", ":", " ", "1"}]}], "]"}], " ", ":=", "  ", 
    RowBox[{"Which", "[", 
     RowBox[{
      RowBox[{"z", " ", ">", " ", "tol"}], ",", " ", "1", ",", " ", 
      RowBox[{"z", " ", "<", " ", 
       RowBox[{"-", "tol"}]}], ",", " ", 
      RowBox[{"-", "1"}], ",", " ", "True", ",", " ", "default"}], "]"}]}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
