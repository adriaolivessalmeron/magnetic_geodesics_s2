         RowBox[{"\"\<EE\>\"", " ", "->", " ", "EE"}], ",", 
         RowBox[{"\"\<a0\>\"", " ", "->", " ", "a0"}], ",", " ", 
         RowBox[{"\"\<a1\>\"", " ", "->", " ", "a1"}], ",", " ", 
         RowBox[{"\"\<a2\>\"", " ", "->", " ", "a2"}], ",", " ", 
         RowBox[{"\"\<a3\>\"", " ", "->", " ", "a3"}], ",", 
         RowBox[{"\"\<Degree\>\"", " ", "->", " ", "deg"}], ",", 
         RowBox[{"\"\<ConstraintDefect\>\"", " ", "->", " ", "defect"}], ",", 
         RowBox[{"\"\<P1\>\"", " ", "->", " ", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"ell", " ", "+", " ", 
               RowBox[{"q", " ", "mu", " ", "lambdaI", " ", 
                RowBox[{"R", "^", "2"}]}]}], ")"}], "^", "2"}]}], "/", 
           RowBox[{"R", "^", "4"}]}]}], ",", 
         RowBox[{"\"\<Pm1\>\"", " ", "->", " ", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"ell", " ", "-", " ", 
               RowBox[{"q", " ", "mu", " ", "lambdaI", " ", 
                RowBox[{"R", "^", "2"}]}]}], ")"}], "^", "2"}]}], "/", 
           RowBox[{"R", "^", "4"}]}]}]}], "\n", "   ", "}"}]}]}], "\n", "  ", 
     "]"}]}], ";"}], "\n"}], "\n"}], "Input",
